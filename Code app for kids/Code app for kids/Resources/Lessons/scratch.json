          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "What do we call the color group that moves your sprite?",
            "codeBefore": "",
            "codeAfter": " blocks",
            "choices": ["Motion", "Sound", "Looks"],
            "correctIndex": 0,
            "explanation": "Motion blocks change position."
          }
        }
      ]
    },
