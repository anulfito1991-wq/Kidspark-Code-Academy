{
  "languageID": "javascript",
  "lessons": [
    {
      "id": "javascript-b1",
      "languageID": "javascript",
      "tier": "basics",
      "order": 0,
      "title": "Hello, JavaScript",
      "summary": "Say hi from the web.",
      "xpReward": 20,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "console.log",
            "body": "In JavaScript, console.log prints messages you can see in the developer console.",
            "codeSample": "console.log(\"Hello, world!\");"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which one prints in JavaScript?",
            "options": ["print()", "console.log()", "echo()"],
            "correctIndex": 1,
            "explanation": "console.log is JavaScript's print."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Print the word Coding.",
            "codeBefore": "console.log(",
            "codeAfter": ");",
            "choices": ["\"Coding\"", "Coding", ":Coding"],
            "correctIndex": 0,
            "explanation": "Wrap text in quotes."
          }
        }
      ]
    },
    {
      "id": "javascript-b2",
      "languageID": "javascript",
      "tier": "basics",
      "order": 1,
      "title": "let and const",
      "summary": "Name a value you can use later.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Two keywords",
            "body": "Use const for values that won't change, and let for values that can.",
            "codeSample": "const name = \"Ada\";\nlet score = 0;\nscore = score + 1;"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which keyword lets you change the value later?",
            "options": ["const", "let", "var const"],
            "correctIndex": 1,
            "explanation": "let can be reassigned. const cannot."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Declare a constant called PI.",
            "codeBefore": "",
            "codeAfter": " PI = 3.14;",
            "choices": ["const", "let", "def"],
            "correctIndex": 0,
            "explanation": "PI won't change — use const."
          }
        }
      ]
    },
    {
      "id": "javascript-b3",
      "languageID": "javascript",
      "tier": "basics",
      "order": 2,
      "title": "Numbers and math",
      "summary": "Calculator time.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Operators",
            "body": "+ adds, - subtracts, * multiplies, / divides, % is remainder.",
            "codeSample": "console.log(10 % 3);"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does 10 % 3 give?",
            "options": ["3", "1", "0"],
            "correctIndex": 1,
            "explanation": "% is remainder. 10 divided by 3 is 3 with 1 left over."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Make sum equal 14.",
            "codeBefore": "let sum = 7 ",
            "codeAfter": " 2;",
            "choices": ["*", "+", "-"],
            "correctIndex": 0,
            "explanation": "7 * 2 is 14."
          }
        }
      ]
    },
    {
      "id": "javascript-b4",
      "languageID": "javascript",
      "tier": "basics",
      "order": 3,
      "title": "Template strings",
      "summary": "Drop values into text.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Backticks",
            "body": "Template strings use backticks and ${ } to slot values in.",
            "codeSample": "const name = \"Sam\";\nconsole.log(`Hi, ${name}!`);"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which character starts a template string?",
            "options": ["\"", "'", "`"],
            "correctIndex": 2,
            "explanation": "The backtick character `."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Insert score into the template string.",
            "codeBefore": "console.log(`Score: ",
            "codeAfter": "`);",
            "choices": ["${score}", "{score}", "[score]"],
            "correctIndex": 0,
            "explanation": "${ } inserts a variable."
          }
        }
      ]
    },
    {
      "id": "javascript-b5",
      "languageID": "javascript",
      "tier": "basics",
      "order": 4,
      "title": "if / else",
      "summary": "Make the code decide.",
      "xpReward": 30,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Branching",
            "body": "JavaScript uses if ( ) { } and optionally else { }.",
            "codeSample": "const age = 10;\nif (age >= 13) {\n  console.log(\"Teen\");\n} else {\n  console.log(\"Kid\");\n}"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What goes around the condition in an if statement?",
            "options": ["[ ]", "( )", "\" \""],
            "correctIndex": 1,
            "explanation": "Parentheses hold the condition."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Check if x is equal to 5 (strict).",
            "codeBefore": "if (x ",
            "codeAfter": " 5) {}",
            "choices": ["===", "=", "=="],
            "correctIndex": 0,
            "explanation": "=== compares value and type."
          }
        }
      ]
    },
    {
      "id": "javascript-b6",
      "languageID": "javascript",
      "tier": "basics",
      "order": 5,
      "title": "for loops",
      "summary": "Repeat blocks of code.",
      "xpReward": 30,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Counted loops",
            "body": "A for loop has three parts: start, condition, and update.",
            "codeSample": "for (let i = 0; i < 3; i++) {\n  console.log(i);\n}"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does i++ do?",
            "options": ["Stops the loop", "Adds 1 to i", "Prints i"],
            "correctIndex": 1,
            "explanation": "i++ is shorthand for i = i + 1."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Start a loop that runs 5 times.",
            "codeBefore": "for (let i = 0; i ",
            "codeAfter": " 5; i++) {}",
            "choices": ["<", "<=", "="],
            "correctIndex": 0,
            "explanation": "< 5 with start 0 gives 5 loops."
          }
        }
      ]
    },
    {
      "id": "javascript-i1",
      "languageID": "javascript",
      "tier": "intermediate",
      "order": 6,
      "title": "Functions",
      "summary": "Reusable blocks of behavior.",
      "xpReward": 40,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Declaring a function",
            "body": "Use function, a name, parameters in ( ), and a body in { }.",
            "codeSample": "function greet(name) {\n  console.log(`Hi, ${name}!`);\n}\ngreet(\"Sam\");"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which keyword declares a classic JavaScript function?",
            "options": ["def", "func", "function"],
            "correctIndex": 2,
            "explanation": "JavaScript uses function."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Start a function named wave.",
            "codeBefore": "",
            "codeAfter": " wave() {}",
            "choices": ["function", "def", "let"],
            "correctIndex": 0,
            "explanation": "function is the keyword."
          }
        }
      ]
    },
    {
      "id": "javascript-i2",
      "languageID": "javascript",
      "tier": "intermediate",
      "order": 7,
      "title": "Arrays",
      "summary": "Lists in square brackets.",
      "xpReward": 40,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Making and reading arrays",
            "body": "An array is an ordered list in [ ]. Use [index] to read, starting at 0.",
            "codeSample": "const colors = [\"red\", \"green\", \"blue\"];\nconsole.log(colors[0]);"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does colors[2] print?",
            "options": ["red", "green", "blue"],
            "correctIndex": 2,
            "explanation": "Index 2 is the third item."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Add \"yellow\" to the end of colors.",
            "codeBefore": "colors.",
            "codeAfter": "(\"yellow\");",
            "choices": ["push", "add", "append"],
            "correctIndex": 0,
            "explanation": "push adds to the end of an array."
          }
        }
      ]
    },
    {
      "id": "javascript-i3",
      "languageID": "javascript",
      "tier": "intermediate",
      "order": 8,
      "title": "Objects",
      "summary": "Group related data with key: value pairs.",
      "xpReward": 45,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Objects hold labeled values",
            "body": "An object uses { } with key: value pairs. Access a value using dot notation like player.name.",
            "codeSample": "const player = {\n  name: \"Alex\",\n  score: 100,\n  alive: true\n};\nconsole.log(player.name);"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "How do you read the score in player = { name: \"Alex\", score: 100 }?",
            "options": ["player[score]", "player.score", "player->score"],
            "correctIndex": 1,
            "explanation": "Dot notation: player.score."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Change the player's score to 200.",
            "codeBefore": "player.",
            "codeAfter": " = 200;",
            "choices": ["score", "name", "alive"],
            "correctIndex": 0,
            "explanation": "You assign a new value to the score key."
          }
        }
      ]
    },
    {
      "id": "javascript-i4",
      "languageID": "javascript",
      "tier": "intermediate",
      "order": 9,
      "title": "map and filter",
      "summary": "Transform and pick array items.",
      "xpReward": 45,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Array superpowers",
            "body": "map makes a new array by transforming each item. filter makes a new array with only items that pass a test.",
            "codeSample": "const nums = [1, 2, 3, 4];\nconst doubled = nums.map(n => n * 2);\nconst evens = nums.filter(n => n % 2 === 0);"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which method keeps only items that match a condition?",
            "options": ["map", "filter", "push"],
            "correctIndex": 1,
            "explanation": "filter keeps items where the test returns true."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Double every number in nums.",
            "codeBefore": "const doubled = nums.",
            "codeAfter": "(n => n * 2);",
            "choices": ["map", "filter", "forEach"],
            "correctIndex": 0,
            "explanation": "map transforms each item into a new one."
          }
        }
      ]
    },
    {
      "id": "javascript-i5",
      "languageID": "javascript",
      "tier": "intermediate",
      "order": 10,
      "title": "Arrow functions",
      "summary": "A shorter way to write functions.",
      "xpReward": 45,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "The => syntax",
            "body": "Arrow functions are compact. (params) => expression returns the expression automatically. For more than one line, use { } and a return statement.",
            "codeSample": "const square = n => n * n;\nconst add = (a, b) => a + b;\nconsole.log(square(5));"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does const double = n => n * 2 return when called with 6?",
            "options": ["6", "12", "26"],
            "correctIndex": 1,
            "explanation": "n * 2 with n = 6 is 12."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Complete the arrow.",
            "codeBefore": "const greet = name ",
            "codeAfter": " `Hi ${name}`;",
            "choices": ["=>", "->", "=="],
            "correctIndex": 0,
            "explanation": "JavaScript arrow functions use =>."
          }
        }
      ]
    },
    {
      "id": "javascript-a1",
      "languageID": "javascript",
      "tier": "advanced",
      "order": 11,
      "title": "DOM basics",
      "summary": "Change a webpage with JavaScript.",
      "xpReward": 60,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Finding elements",
            "body": "The DOM is the tree of elements on a page. document.querySelector finds the first element matching a CSS selector. You can read and change its textContent.",
            "codeSample": "const title = document.querySelector(\"h1\");\ntitle.textContent = \"Hello from JS!\";"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which method finds the first matching element?",
            "options": ["document.find", "document.querySelector", "document.getByTag"],
            "correctIndex": 1,
            "explanation": "querySelector takes any CSS selector."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Change the text inside the selected element.",
            "codeBefore": "el.",
            "codeAfter": " = \"Hi!\";",
            "choices": ["textContent", "innerValue", "value"],
            "correctIndex": 0,
            "explanation": "textContent sets the text inside an element."
          }
        }
      ]
    },
    {
      "id": "javascript-a2",
      "languageID": "javascript",
      "tier": "advanced",
      "order": 12,
      "title": "Events",
      "summary": "Respond to clicks and key presses.",
      "xpReward": 65,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "addEventListener",
            "body": "Elements fire events like 'click'. Use addEventListener to run a function when the event happens.",
            "codeSample": "const btn = document.querySelector(\"button\");\nbtn.addEventListener(\"click\", () => {\n  console.log(\"Clicked!\");\n});"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which event fires when you press a mouse button on an element?",
            "options": ["click", "hover", "load"],
            "correctIndex": 0,
            "explanation": "click fires on mouse press and release."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Attach a click handler.",
            "codeBefore": "btn.",
            "codeAfter": "(\"click\", handle);",
            "choices": ["addEventListener", "on", "bind"],
            "correctIndex": 0,
            "explanation": "addEventListener is the standard way."
          }
        }
      ]
    },
    {
      "id": "javascript-a3",
      "languageID": "javascript",
      "tier": "advanced",
      "order": 13,
      "title": "async and await",
      "summary": "Wait for slow things without blocking.",
      "xpReward": 70,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Promises made readable",
            "body": "An async function can use await to pause until a Promise finishes. This lets you write code that waits for the network without freezing the page.",
            "codeSample": "async function loadData() {\n  const res = await fetch(\"/api/data\");\n  const data = await res.json();\n  console.log(data);\n}"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Where can you use await?",
            "options": ["Anywhere", "Only inside async functions", "Only in loops"],
            "correctIndex": 1,
            "explanation": "await only works inside functions marked async."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Mark this function so it can await.",
            "codeBefore": "",
            "codeAfter": " function load() { await fetch(\"/x\"); }",
            "choices": ["async", "await", "promise"],
            "correctIndex": 0,
            "explanation": "async before function enables await inside."
          }
        }
      ]
    }
  ]
}
