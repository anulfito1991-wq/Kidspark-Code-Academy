        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Add a new name and age.",
            "codeBefore": "ages[",
            "codeAfter": "] = 9",
            "choices": ["\"Jo\"", "Jo", "0"],
            "correctIndex": 0,
            "explanation": "String keys need quotes around them."
          }
        }
      ]
    },
    {
      "id": "python-i4",
      "languageID": "python",
      "tier": "intermediate",
      "order": 9,
      "title": "Returning values",
