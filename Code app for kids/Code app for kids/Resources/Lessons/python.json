        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Check if score equals 10.",
            "codeBefore": "if score ",
            "codeAfter": " 10:",
            "choices": ["==", "=", "!"],
            "correctIndex": 0,
            "explanation": "== checks equality. = would assign."
          }
        }
      ]
