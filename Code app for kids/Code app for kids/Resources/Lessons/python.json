      "summary": "Store values by name, not position.",
      "xpReward": 45,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Key-value pairs",
            "body": "A dictionary pairs keys with values. Use { } to make one, and [key] to read a value. Great for game scores, settings, or user data.",
