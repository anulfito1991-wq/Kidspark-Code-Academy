            "explanation": "return ends the function and gives the value back."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Return the square of x.",
            "codeBefore": "def square(x):\n    ",
            "codeAfter": " x * x",
            "choices": ["return", "print", "yield"],
            "correctIndex": 0,
            "explanation": "return hands the value to whoever called the function."
          }
        }
      ]
    },
    {
      "id": "python-i5",
      "languageID": "python",
      "tier": "intermediate",
