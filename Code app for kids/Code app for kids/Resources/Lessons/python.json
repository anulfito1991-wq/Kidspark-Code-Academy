      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "return",
            "body": "Functions can hand a value back with return. Save the result in a variable or use it directly.",
            "codeSample": "def double(x):\n    return x * 2\nresult = double(5)\nprint(result) # 10"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does return do?",
            "options": ["Restarts the function", "Sends a value back to the caller", "Prints to the screen"],
