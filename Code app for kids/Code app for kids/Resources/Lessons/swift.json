{
  "languageID": "swift",
  "lessons": [
    {
      "id": "swift-b1",
      "languageID": "swift",
      "tier": "basics",
      "order": 0,
      "title": "Hello, Swift",
      "summary": "Make your first Swift program talk to you.",
      "xpReward": 20,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Say hello",
            "body": "Computers do what you tell them. In Swift, print() shows text on the screen.",
            "codeSample": "print(\"Hello, world!\")"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does print do?",
            "options": ["Turns on the printer", "Shows text on the screen", "Saves a file"],
            "correctIndex": 1,
            "explanation": "print writes text to the output, so you can see it."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Finish the line to print Hi.",
            "codeBefore": "print(",
            "codeAfter": ")",
            "choices": ["\"Hi\"", "Hi", "=Hi"],
            "correctIndex": 0,
            "explanation": "Text in Swift goes inside double quotes."
          }
        }
      ]
    },
    {
      "id": "swift-b2",
      "languageID": "swift",
      "tier": "basics",
      "order": 1,
      "title": "Boxes called variables",
      "summary": "Store numbers and words so you can use them later.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "let and var",
            "body": "A variable is a name for a value. Use let when the value will not change, and var when it might.",
            "codeSample": "let name = \"Ada\"\nvar score = 0"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "Which keyword makes a value that can change?",
            "options": ["let", "var", "print"],
            "correctIndex": 1,
            "explanation": "var is variable — it can change. let is a constant."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Store the number 10 in a constant called age.",
            "codeBefore": "",
            "codeAfter": " age = 10",
            "choices": ["let", "var", "num"],
            "correctIndex": 0,
            "explanation": "age won't change, so let is best."
          }
        }
      ]
    },
    {
      "id": "swift-b3",
      "languageID": "swift",
      "tier": "basics",
      "order": 2,
      "title": "Doing math",
      "summary": "Add, subtract, multiply, divide.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Number operators",
            "body": "Swift knows math. Use + to add, - to subtract, * to multiply, and / to divide.",
            "codeSample": "let total = 3 + 4\nlet doubled = total * 2"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What is 6 * 2 in Swift?",
            "options": ["8", "12", "3"],
            "correctIndex": 1,
            "explanation": "* is multiply, so 6 * 2 is 12."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Finish so sum equals 10.",
            "codeBefore": "let sum = 6 ",
            "codeAfter": " 4",
            "choices": ["+", "-", "/"],
            "correctIndex": 0,
            "explanation": "6 + 4 is 10."
          }
        }
      ]
    },
    {
      "id": "swift-b4",
      "languageID": "swift",
      "tier": "basics",
      "order": 3,
      "title": "Working with words",
      "summary": "Stick strings together.",
      "xpReward": 25,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Joining strings",
            "body": "Strings are words and sentences. You can join them with +.",
            "codeSample": "let hi = \"Hello, \" + \"friend\"\nprint(hi)"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What prints from: print(\"Sw\" + \"ift\")?",
            "options": ["Sw ift", "Swift", "Sw+ift"],
            "correctIndex": 1,
            "explanation": "+ joins the two pieces into \"Swift\"."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Join greeting and name.",
            "codeBefore": "let message = \"Hi \" ",
            "codeAfter": " name",
            "choices": ["+", "*", ":"],
            "correctIndex": 0,
            "explanation": "+ joins strings together."
          }
        }
      ]
    },
    {
      "id": "swift-b5",
      "languageID": "swift",
      "tier": "basics",
      "order": 4,
      "title": "Making choices",
      "summary": "Use if to decide what happens.",
      "xpReward": 30,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "if statements",
            "body": "An if statement runs code only when a condition is true.",
            "codeSample": "let score = 8\nif score > 5 {\n    print(\"Nice!\")\n}"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "When does the print inside the if run?",
            "options": ["Always", "Only when score > 5", "Never"],
            "correctIndex": 1,
            "explanation": "The body runs only while the condition is true."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Run the code only when age is at least 13.",
            "codeBefore": "if age ",
            "codeAfter": " 13 { ... }",
            "choices": [">=", "=", "!="],
            "correctIndex": 0,
            "explanation": ">= means greater than or equal."
          }
        }
      ]
    },
    {
      "id": "swift-b6",
      "languageID": "swift",
      "tier": "basics",
      "order": 5,
      "title": "Doing it again with loops",
      "summary": "Repeat without retyping.",
      "xpReward": 30,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "for-in loops",
            "body": "A for-in loop repeats code for each item in a range or list.",
            "codeSample": "for i in 1...3 {\n    print(i)\n}"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What does the loop above print?",
            "options": ["1 then 2 then 3", "Only 3", "Nothing"],
            "correctIndex": 0,
            "explanation": "1...3 means 1, 2, 3. The loop runs three times."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Loop 5 times using numbers 1 through 5.",
            "codeBefore": "for i in 1",
            "codeAfter": "5 { print(i) }",
            "choices": ["...", "..", "->"],
            "correctIndex": 0,
            "explanation": "... is Swift's closed range operator."
          }
        }
      ]
    },
    {
      "id": "swift-i1",
      "languageID": "swift",
      "tier": "intermediate",
      "order": 6,
      "title": "Functions do jobs",
      "summary": "Wrap code so you can call it by name.",
      "xpReward": 40,
      "steps": [
        {
          "kind": "explainer",
          "payload": {
            "title": "Declaring a function",
            "body": "A function groups steps under a name. Use func, add parameters in (), and code in { }.",
            "codeSample": "func greet(name: String) {\n    print(\"Hi, \\(name)!\")\n}\ngreet(name: \"Sam\")"
          }
        },
        {
          "kind": "mcq",
          "payload": {
            "prompt": "What keyword starts a function in Swift?",
            "options": ["def", "function", "func"],
            "correctIndex": 2,
            "explanation": "Swift uses func."
          }
        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Complete the function declaration.",
            "codeBefore": "",
            "codeAfter": " wave() { print(\"👋\") }",
            "choices": ["func", "let", "var"],
            "correctIndex": 0,
            "explanation": "func declares a function."
          }
        }
      ]
    },
    {
