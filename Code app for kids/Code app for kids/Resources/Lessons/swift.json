        },
        {
          "kind": "codeFill",
          "payload": {
            "prompt": "Get the second item from the array.",
            "codeBefore": "colors",
            "codeAfter": "",
            "choices": ["[1]", "[2]", "(1)"],
            "correctIndex": 0,
            "explanation": "Index 1 is the second item because arrays start at 0."
